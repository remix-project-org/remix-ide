msgid "Gas Limit:"
msgstr ""

#: ../../run.md:176
msgid "This sets the maximum amount of gas allowed to be spent for all the contract transactions created in Remix."
msgstr ""

#: ../../run.md:179
msgid "Value:"
msgstr ""

#: ../../run.md:181
msgid "This sets the amount of ETH, WEI, Gwei, etc. that is sent to a contract or a payable function. <br> **Note:** payable functions have a red button."
msgstr ""

